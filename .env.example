# Container run mode: gradio | api | both
RUN_MODE=gradio

# Build controls
# CUDA_VARIANT: runtime | devel
# Use devel if uv needs to compile GPU dependencies from source on your platform.
CUDA_VARIANT=runtime
# Install bitsandbytes during image build (recommended for 8-bit optimizer support)
INSTALL_BITSANDBYTES=true

# Network binding inside container
SERVER_NAME=0.0.0.0
PORT=7860
ACESTEP_API_HOST=0.0.0.0
ACESTEP_API_PORT=8000
# Docker host binding for published ports (set 0.0.0.0 for Lightning public URLs)
HOST_BIND_IP=0.0.0.0

# HuggingFace token (optional, for private models)
HF_TOKEN=

# ACE-Step model settings
ACESTEP_CONFIG_PATH=acestep-v15-turbo
ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-1.7B
ACESTEP_DEVICE=auto
ACESTEP_LM_BACKEND=vllm
ACESTEP_USE_FLASH_ATTENTION=true

# Startup model pre-download (wrapper behavior)
ACESTEP_AUTO_DOWNLOAD_MODELS=true
ACESTEP_PRELOAD_MODELS=acestep-v15-xl-base,acestep-5Hz-lm-4B
# Run model preloads in background so Gradio can become available sooner (recommended on Lightning)
ACESTEP_PRELOAD_BACKGROUND=true
# If preload fails and this is true, container startup fails
ACESTEP_PRELOAD_FATAL=false
# If a preloaded model folder exists but is incomplete/invalid, force re-download it.
ACESTEP_REPAIR_INVALID_MODELS=true

# LLM initialization: auto | true | false
ACESTEP_INIT_LLM=auto

# Model source: auto | huggingface | modelscope
ACESTEP_DOWNLOAD_SOURCE=auto

# Optional API auth
ACESTEP_API_KEY=

# Optional UI settings
LANGUAGE=en
# ACESTEP_BATCH_SIZE=2

# Lazy initialization at API startup: true to skip eager model loading
# ACESTEP_NO_INIT=true
