# Container run mode: gradio | api | both
RUN_MODE=gradio

# Build controls
# CUDA_VARIANT: runtime | devel (use devel for source builds, e.g. required flash-attn)
CUDA_VARIANT=runtime
# FLASH_ATTN_MODE: off | auto | required
FLASH_ATTN_MODE=auto

# Network binding inside container
SERVER_NAME=0.0.0.0
PORT=7860
ACESTEP_API_HOST=0.0.0.0
ACESTEP_API_PORT=8000

# HuggingFace token (optional, for private models)
HF_TOKEN=

# ACE-Step model settings
ACESTEP_CONFIG_PATH=acestep-v15-turbo
ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-1.7B
ACESTEP_DEVICE=auto
ACESTEP_LM_BACKEND=vllm

# LLM initialization: auto | true | false
ACESTEP_INIT_LLM=auto

# Model source: auto | huggingface | modelscope
ACESTEP_DOWNLOAD_SOURCE=auto

# Optional API auth
ACESTEP_API_KEY=

# Optional UI settings
LANGUAGE=en
# ACESTEP_BATCH_SIZE=2

# Lazy initialization at API startup: true to skip eager model loading
# ACESTEP_NO_INIT=true
